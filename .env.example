# BioHermes Configuration
# Copy to .env and fill in values

# MinerU API
MINERU_API_URL=http://10.123.45.9:8500

# LLM (Anthropic-compatible API)
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://open.bigmodel.cn/api/anthropic
LLM_MODEL=GLM-5.1

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=9091

# Agent
MAX_RETRIES=3
MAX_CONCURRENT_PARSE=3
PARSE_TIMEOUT=300
